---
import Layout from '@/layouts/Layout.astro';
import PostCard from '@/components/PostCard.svelte';
import Breadcrumbs from '@/components/Breadcrumbs.svelte';
import { getReadTime } from '@/lib/utils/readTime';
import { getPublishedPosts, getPostSlug } from '@/lib/utils/posts';
import { SITE } from '@/config';
import { getBreadcrumbSchema } from '@/lib/schemas';

const schema = getBreadcrumbSchema([
  { name: '전체 글', url: new URL('/posts', Astro.site).toString() },
]);

const posts = (await getPublishedPosts()).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Group posts by year
const groupedPosts = posts.reduce(
  (acc, post) => {
    const year = post.data.pubDate.getFullYear().toString();
    if (!acc[year]) acc[year] = [];
    acc[year].push(post);
    return acc;
  },
  {} as Record<string, typeof posts>
);

const years = Object.keys(groupedPosts).sort((a, b) => b.localeCompare(a));

// Get all tags with counts
const tagCounts = posts.reduce(
  (acc, post) => {
    post.data.tags?.forEach((tag) => {
      acc[tag] = (acc[tag] || 0) + 1;
    });
    return acc;
  },
  {} as Record<string, number>
);

// Sort tags by count (descending)
const sortedTags = Object.entries(tagCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 20); // Top 20 tags
---

<Layout title="전체 글" description={SITE.blogDescription} schema={schema}>
  <Breadcrumbs items={[{ name: '전체 글', href: '/posts' }]} />

  <div class="mb-10 sm:mb-14">
    <h1
      class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-foreground leading-[1.1]"
    >
      아티클
    </h1>
    <p class="mt-3 text-base sm:text-lg text-muted-foreground max-w-2xl leading-relaxed">
      {SITE.blogDescription}
    </p>
  </div>

  <!-- Tags Filter -->
  <div class="mb-10 sm:mb-12">
    <div class="flex flex-wrap gap-2">
      <a
        href="/posts"
        class="inline-flex items-center px-3.5 py-2 rounded-lg text-sm font-medium bg-pluglink-blue text-white no-underline"
      >
        전체
        <span class="ml-1.5 text-white/70">({posts.length})</span>
      </a>
      {
        sortedTags.map(([tag, count]) => (
          <a
            href={`/posts/tag/${tag}`}
            class="inline-flex items-center px-3.5 py-2 rounded-lg text-sm font-medium bg-secondary text-foreground hover:bg-accent border border-border/50 hover:border-pluglink-blue/30 transition-all no-underline"
          >
            {tag}
            <span class="ml-1.5 text-muted-foreground">({count})</span>
          </a>
        ))
      }
    </div>
  </div>

  <!-- Posts List -->
  <div class="flex flex-col gap-10 lg:gap-12">
    {
      years.map((year) => (
        <section class="flex flex-col gap-2">
          <div class="flex items-center gap-4 mb-2">
            <h2 class="text-sm font-bold text-pluglink-blue tabular-nums shrink-0">{year}</h2>
            <div class="h-px flex-1 bg-border/60" />
            <span class="text-xs text-muted-foreground shrink-0">
              {groupedPosts[year].length}개
            </span>
          </div>
          <div class="flex flex-col">
            {groupedPosts[year].map((post) => (
              <PostCard {post} slug={getPostSlug(post)} readTime={getReadTime(post.body || '')} />
            ))}
          </div>
        </section>
      ))
    }
  </div>
</Layout>
