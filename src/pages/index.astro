---
import Layout from '@/layouts/Layout.astro';
import { getReadTime } from '@/lib/utils/readTime';
import { getPublishedPosts, getPostSlug } from '@/lib/utils/posts';
import { formatDate } from '@/lib/utils/date';
import { SITE } from '@/config';

const posts = (await getPublishedPosts()).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPosts = posts.filter((post) => post.data.featured).slice(0, SITE.featuredPostsCount);
const latestPosts = posts.filter((post) => !post.data.featured).slice(0, SITE.latestPostsCount);

// Category definitions
const categories = [
  {
    name: 'Engineering',
    tag: 'engineering',
    desc: '서비스 개발과 운영에 대한 기술적 도전과 해결 과정',
    icon: 'code',
    count: posts.filter((p) => p.data.tags.includes('engineering')).length,
  },
  {
    name: 'Design',
    tag: 'design',
    desc: '사용자 경험과 인터페이스 디자인에 대한 이야기',
    icon: 'palette',
    count: posts.filter((p) => p.data.tags.includes('design')).length,
  },
  {
    name: 'Product',
    tag: 'product',
    desc: '프로덕트를 만들어가는 과정과 의사결정의 기록',
    icon: 'box',
    count: posts.filter((p) => p.data.tags.includes('product')).length,
  },
  {
    name: 'Culture',
    tag: 'culture',
    desc: '플러그링크의 팀 문화와 일하는 방식',
    icon: 'users',
    count: posts.filter((p) => p.data.tags.includes('culture')).length,
  },
];
---

<Layout title="Tech Blog">
  <!-- Hero Section -->
  <section class="pt-4 sm:pt-6 pb-10 sm:pb-14">
    <div class="max-w-3xl">
      <div class="flex items-center gap-2 mb-6">
        <div class="w-1 h-6 rounded-full bg-pluglink-blue"></div>
        <span class="text-sm font-bold text-pluglink-blue tracking-wide">PLUGLINK TECH BLOG</span>
      </div>
      <h1
        class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-foreground leading-[1.08] mb-6"
      >
        기술이 세상을<br />
        <span class="text-pluglink-blue">연결</span>하는 방법
      </h1>
      <p class="text-lg sm:text-xl text-muted-foreground leading-relaxed max-w-2xl">
        플러그링크 팀이 서비스를 만들며 겪은 기술적 도전과 해결 과정, 그리고 팀의 성장 이야기를
        공유합니다.
      </p>
    </div>
  </section>

  <!-- Category Cards - toss.tech style -->
  <section class="mb-20 sm:mb-28">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
      {
        categories.map((cat) => (
          <a
            href={`/posts/tag/${cat.tag}`}
            class="group relative p-5 sm:p-6 rounded-2xl bg-card border border-border/50 hover:border-pluglink-blue/30 hover:shadow-lg hover:shadow-pluglink-blue/5 transition-all duration-300 no-underline"
          >
            <div class="mb-3 sm:mb-4">
              {cat.icon === 'code' && (
                <div class="w-10 h-10 rounded-xl bg-blue-50 dark:bg-blue-950/50 flex items-center justify-center">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#0066FF"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="16 18 22 12 16 6" />
                    <polyline points="8 6 2 12 8 18" />
                  </svg>
                </div>
              )}
              {cat.icon === 'palette' && (
                <div class="w-10 h-10 rounded-xl bg-purple-50 dark:bg-purple-950/50 flex items-center justify-center">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#8b5cf6"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="13.5" cy="6.5" r=".5" fill="#8b5cf6" />
                    <circle cx="17.5" cy="10.5" r=".5" fill="#8b5cf6" />
                    <circle cx="8.5" cy="7.5" r=".5" fill="#8b5cf6" />
                    <circle cx="6.5" cy="12.5" r=".5" fill="#8b5cf6" />
                    <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z" />
                  </svg>
                </div>
              )}
              {cat.icon === 'box' && (
                <div class="w-10 h-10 rounded-xl bg-emerald-50 dark:bg-emerald-950/50 flex items-center justify-center">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#10b981"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="m7.5 4.27 9 5.15" />
                    <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" />
                    <path d="m3.3 7 8.7 5 8.7-5" />
                    <path d="M12 22V12" />
                  </svg>
                </div>
              )}
              {cat.icon === 'users' && (
                <div class="w-10 h-10 rounded-xl bg-amber-50 dark:bg-amber-950/50 flex items-center justify-center">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#f59e0b"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                  </svg>
                </div>
              )}
            </div>
            <h3 class="text-sm sm:text-base font-bold text-foreground mb-1 group-hover:text-pluglink-blue transition-colors">
              {cat.name}
            </h3>
            <p class="text-xs sm:text-sm text-muted-foreground leading-relaxed line-clamp-2">
              {cat.desc}
            </p>
            {cat.count > 0 && (
              <span class="mt-3 inline-flex text-xs font-medium text-muted-foreground">
                {cat.count}개의 아티클
              </span>
            )}
          </a>
        ))
      }
    </div>
  </section>

  <!-- Featured Posts -->
  {
    featuredPosts.length > 0 && (
      <section class="mb-20 sm:mb-28">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-xl sm:text-2xl font-black tracking-tight text-foreground">주요 아티클</h2>
          <a
            href="/posts"
            class="text-sm font-medium text-muted-foreground hover:text-pluglink-blue transition-colors no-underline flex items-center gap-1"
          >
            전체보기
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m9 18 6-6-6-6" />
            </svg>
          </a>
        </div>
        <div class="grid gap-4 sm:gap-5">
          {featuredPosts.map((post, i) => {
            const slug = getPostSlug(post);
            const readTime = getReadTime(post.body || '');
            return (
              <article class="group relative">
                <a
                  href={`/posts/${slug}`}
                  class="block p-6 sm:p-8 rounded-2xl bg-card border border-border/50 hover:border-pluglink-blue/30 hover:shadow-lg hover:shadow-pluglink-blue/5 transition-all duration-300 no-underline"
                >
                  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3">
                    <div class="flex-1 min-w-0">
                      <div class="flex flex-wrap items-center gap-2 mb-3">
                        {post.data.tags.slice(0, 2).map((tag) => (
                          <span class="inline-flex px-2.5 py-1 rounded-md text-xs font-medium bg-pluglink-blue/8 text-pluglink-blue dark:bg-pluglink-blue/15">
                            {tag}
                          </span>
                        ))}
                      </div>
                      <h3 class="text-lg sm:text-xl font-bold text-foreground leading-snug mb-2 group-hover:text-pluglink-blue transition-colors">
                        {post.data.title}
                      </h3>
                      <p class="text-sm text-muted-foreground leading-relaxed line-clamp-2 max-w-xl">
                        {post.data.description}
                      </p>
                    </div>
                    <div class="flex items-center gap-3 text-xs text-muted-foreground sm:text-right sm:shrink-0 sm:ml-6 sm:pt-8">
                      <time datetime={post.data.pubDate.toISOString()}>
                        {formatDate(post.data.pubDate)}
                      </time>
                      <span class="text-border">·</span>
                      <span>{readTime}</span>
                    </div>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      </section>
    )
  }

  <!-- Latest Posts -->
  <section class="mb-6 sm:mb-8">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-xl sm:text-2xl font-black tracking-tight text-foreground">최신 아티클</h2>
      <a
        href="/posts"
        class="text-sm font-medium text-muted-foreground hover:text-pluglink-blue transition-colors no-underline flex items-center gap-1"
      >
        전체보기
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
        >
      </a>
    </div>
    <div class="grid gap-px bg-border/50 rounded-2xl border border-border/50 overflow-hidden">
      {
        latestPosts.map((post) => {
          const slug = getPostSlug(post);
          const readTime = getReadTime(post.body || '');
          return (
            <article class="group">
              <a
                href={`/posts/${slug}`}
                class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 sm:gap-6 px-6 py-5 bg-card hover:bg-accent/50 transition-all duration-200 no-underline"
              >
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1.5">
                    {post.data.tags.slice(0, 1).map((tag) => (
                      <span class="text-xs font-medium text-pluglink-blue">{tag}</span>
                    ))}
                  </div>
                  <h3 class="text-base font-bold text-foreground leading-snug group-hover:text-pluglink-blue transition-colors truncate">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-muted-foreground mt-1 line-clamp-1 hidden sm:block">
                    {post.data.description}
                  </p>
                </div>
                <div class="flex items-center gap-3 text-xs text-muted-foreground shrink-0">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {formatDate(post.data.pubDate)}
                  </time>
                  <span class="text-border">·</span>
                  <span>{readTime}</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="opacity-0 group-hover:opacity-100 transition-opacity hidden sm:block"
                  >
                    <path d="m9 18 6-6-6-6" />
                  </svg>
                </div>
              </a>
            </article>
          );
        })
      }
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="mb-0">
    <div
      class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-pluglink-blue to-blue-600 p-5 sm:p-6"
    >
      <div class="relative z-10">
        <h2 class="text-xl sm:text-2xl font-black text-white mb-3">플러그링크와 함께 성장하세요</h2>
        <p class="text-blue-100 text-sm sm:text-base mb-6 max-w-lg leading-relaxed">
          혁신적인 기술로 세상을 연결하는 플러그링크에서 함께할 동료를 찾고 있습니다.
        </p>
        <a
          href="https://team.pluglink.kr"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white text-pluglink-blue text-sm font-bold hover:bg-blue-50 transition-colors no-underline"
        >
          채용 바로가기
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg
          >
        </a>
      </div>
      <!-- Decorative -->
      <div
        class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/3 translate-x-1/3"
      >
      </div>
      <div class="absolute bottom-0 left-1/2 w-48 h-48 bg-white/5 rounded-full translate-y-1/2">
      </div>
    </div>
  </section>
</Layout>
