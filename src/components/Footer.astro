---

---

<footer class="mt-10 sm:mt-20 border-t border-border">
  <div class="py-6 sm:py-14">
    <!-- Top: Logo + Social Links -->
    <div class="flex flex-col sm:flex-row justify-between items-start gap-8 mb-10">
      <!-- Footer Logo: PLUGLINK Wordmark -->
      <a href="/" class="no-underline flex items-center gap-0.5 shrink-0">
        <!-- PLUG (dark) + LINK (blue) wordmark style -->
        <svg
          width="24"
          height="24"
          viewBox="0 0 512 512"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="rounded-md mr-2"
        >
          <rect width="512" height="512" rx="96" fill="#0066FF"></rect>
          <path d="M196 80L120 280H185L155 432L360 210H275L320 80H196Z" fill="white"></path>
          <path
            d="M300 190C300 190 340 190 365 210C390 230 400 260 390 290C380 320 350 340 320 340H290"
            stroke="white"
            stroke-width="38"
            stroke-linecap="round"
            fill="none"></path>
        </svg>
        <span class="text-base font-black tracking-tight">
          <span class="text-foreground">PLUG</span><span class="text-pluglink-blue">LINK</span>
        </span>
        <span class="text-sm font-medium text-muted-foreground ml-1.5">Tech</span>
      </a>
    </div>

    <!-- Middle: Terms & Policy Links -->
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-8 text-[13px]">
      <a
        href="https://pluglink.kr/policy"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground hover:text-foreground transition-colors no-underline"
      >
        서비스이용약관
      </a>
      <span class="text-border">|</span>
      <a
        href="https://pluglink.kr/service-location"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground hover:text-foreground transition-colors no-underline"
      >
        위치기반서비스이용약관
      </a>
      <span class="text-border">|</span>
      <a
        href="https://pluglink.kr/privacy"
        target="_blank"
        rel="noopener noreferrer"
        class="font-bold text-foreground hover:text-pluglink-blue transition-colors no-underline"
      >
        개인정보처리방침
      </a>
    </div>

    <!-- Bottom: Company Info -->
    <div class="space-y-2 text-xs text-muted-foreground/70 leading-relaxed">
      <p class="font-medium text-muted-foreground">주식회사 플러그링크</p>
      <p>
        사업자번호 : 536-87-02226
        <span class="mx-1.5 text-border">|</span>
        통신판매업신고 : 2021-서울강남-06797
      </p>
      <p>대표이사 : 강인철</p>
      <p>주소 : 서울특별시 서초구 강남대로 311, 11층</p>
      <p class="pt-3 text-muted-foreground/50">
        Copyright &copy; PLUGLINK INC. All rights reserved.
      </p>
    </div>
  </div>

  <!-- Social Links with Icons -->
  <div class="flex items-center gap-4">
    <!-- Homepage -->
    <a
      href="https://pluglink.kr"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="PLUGLINK 홈페이지"
      class="flex items-center justify-center w-9 h-9 rounded-lg text-muted-foreground hover:text-foreground hover:bg-accent transition-all no-underline"
      title="홈페이지"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><circle cx="12" cy="12" r="10"></circle><path d="M2 12h20"></path><path
          d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
        ></path></svg
      >
    </a>
    <!-- Naver Blog -->
    <a
      href="https://blog.naver.com/pluglink"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="PLUGLINK 네이버 블로그"
      class="flex items-center justify-center w-9 h-9 rounded-lg text-muted-foreground hover:text-foreground hover:bg-accent transition-all no-underline"
      title="네이버 블로그"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="currentColor"
        ><path d="M16.273 12.845 7.376 0H0v24h7.727V11.155L16.624 24H24V0h-7.727v12.845Z"
        ></path></svg
      >
    </a>
    <!-- YouTube -->
    <a
      href="https://www.youtube.com/@pluglink"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="PLUGLINK 유튜브"
      class="flex items-center justify-center w-9 h-9 rounded-lg text-muted-foreground hover:text-foreground hover:bg-accent transition-all no-underline"
      title="유튜브"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="currentColor"
        ><path
          d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
        ></path></svg
      >
    </a>
    <!-- Instagram -->
    <a
      href="https://instagram.com/pluglink_official"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="PLUGLINK 인스타그램"
      class="flex items-center justify-center w-9 h-9 rounded-lg text-muted-foreground hover:text-foreground hover:bg-accent transition-all no-underline"
      title="인스타그램"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path
          d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line
          x1="17.5"
          x2="17.51"
          y1="6.5"
          y2="6.5"></line></svg
      >
    </a>
    <!-- GitHub -->
    <a
      href="https://github.com/plug-link"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="PLUGLINK GitHub"
      class="flex items-center justify-center w-9 h-9 rounded-lg text-muted-foreground hover:text-foreground hover:bg-accent transition-all no-underline"
      title="GitHub"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path
          d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
        ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
      >
    </a>
  </div>
</footer>
